generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products     Product[]
  suppliers    Supplier[]
  orders       Order[]
  salesRecords SaleRecord[]
  members      Member[]
  coupons      Coupon[]
  couponClaims CouponClaim[]
  deliveryCompanies DeliveryCompany[]
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  products Product[]
  orders   Order[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String?
  unit        String   @default("件")
  stock       Int      @default(0)
  minStock    Int      @default(10)
  maxStock    Int      @default(100)
  price       Float    @default(0)
  cost        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  supplierId  Int?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  salesRecords SaleRecord[]
  orderItems   OrderItem[]
  aiSuggestions AISuggestion[]
}

model SaleRecord {
  id        Int      @id @default(autoincrement())
  quantity  Int
  salePrice Float
  saleDate  DateTime @default(now())
  createdAt DateTime @default(now())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  memberId  Int?
  member    Member?  @relation(fields: [memberId], references: [id])
}

model Order {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique
  status      String   @default("pending")
  totalAmount Float    @default(0)
  expectedDate DateTime?
  arrivedDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  supplierId  Int
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  trackingNumber String?
  logisticsCompany String?
  logisticsStatus String?

  items OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  price     Float
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model AISuggestion {
  id           Int      @id @default(autoincrement())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  suggestQty   Int
  reason       String
  urgency      String   @default("medium")
  predictedSales Int   @default(0)
  confidence   Float    @default(0.5)
  createdAt    DateTime @default(now())
}

model Member {
  id        Int      @id @default(autoincrement())
  phone     String
  name      String?
  level     String   @default("normal")
  points    Int      @default(0)
  totalSpent Float   @default(0)
  birthday  DateTime?
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  records   MemberPointRecord[]
  salesRecords SaleRecord[]
}

model MemberPointRecord {
  id        Int      @id @default(autoincrement())
  type      String
  points    Int
  balance   Int
  remark    String?
  createdAt DateTime @default(now())
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id])
}

model Coupon {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  value     Float
  minAmount Float   @default(0)
  validDays Int      @default(30)
  totalCount Int    @default(100)
  usedCount  Int     @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  claims    CouponClaim[]
}

model CouponClaim {
  id        Int      @id @default(autoincrement())
  claimedAt DateTime @default(now())
  expiredAt DateTime
  status    String   @default("unused")
  usedAt    DateTime?
  createdAt DateTime @default(now())
  couponId  Int
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model DeliveryCompany {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  website   String?
  phone     String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  shipments Shipment[]
}

model Shipment {
  id        Int      @id @default(autoincrement())
  orderNo   String
  status    String   @default("pending")
  expressNo String
  createdAt DateTime @default(now())
  shippedAt DateTime?
  deliveredAt DateTime?
  receiverName  String?
  receiverPhone String?
  receiverAddr String?
  companyId  Int?
  company    DeliveryCompany? @relation(fields: [companyId], references: [id])

  tracks    ShipmentTrack[]
}

model ShipmentTrack {
  id        Int      @id @default(autoincrement())
  status    String
  location  String?
  time      DateTime
  remark    String?
  shipmentId Int
  shipment  Shipment @relation(fields: [shipmentId], references: [id])
}
